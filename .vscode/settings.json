{
    "files.exclude": {
        "src/main/__pycache__": true,
        "src/main/world_objects/__pycache__": true,
        "src/tests/__pycache__": true,
        "src/tests/degrees/__pycache__": true,
        "src/tests/position/__pycache__": true,
        "src/tests/robot/__pycache__": true,
        "src/main/world_objects/__init__.py": true,
        "src/tests/degrees/__init__.py": true,
        "src/tests/position/__init__.py": true,
        "src/tests/robot/__init__.py": true,
        "src/tests/__init__.py": true,
        "src/main/__init__.py": true,
        "{s,[!s]*,sr,s[!r]*,sr[!c]*,src?*}": true
    },
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./src",
        "-p",
        "test_*.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "folder-scopes.scopes": {
        "focus": {
            "toyrobot6": {
                "scopedFolderPath": "src",
                "excludedPaths": [
                    "src/main/__pycache__",
                    "src/main/world_objects/__pycache__",
                    "src/tests/__pycache__",
                    "src/tests/degrees/__pycache__",
                    "src/tests/position/__pycache__",
                    "src/tests/robot/__pycache__",
                    "src/main/world_objects/__init__.py",
                    "src/tests/degrees/__init__.py",
                    "src/tests/position/__init__.py",
                    "src/tests/robot/__init__.py",
                    "src/tests/__init__.py",
                    "src/main/__init__.py"
                ]
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "comments": "",
        "textMateRules": []
    }
}
